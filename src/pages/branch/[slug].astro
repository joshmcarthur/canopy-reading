---
import Layout from '../../layouts/Layout.astro';
import { getBranch, getBranchEvents } from '../../lib/dal';
import { projectBranchState } from '../../domain/projection';

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/');
}

const branch = await getBranch(slug);
if (!branch) {
  return Astro.redirect('/404');
}

const events = await getBranchEvents(slug);
const state = projectBranchState(events);
---

<Layout>
  <main class="container mx-auto max-w-4xl py-12 px-6">
    <div class="mb-8">
      <a href="/" class="text-sm text-muted-foreground hover:text-charcoal-900 transition-colors">&larr; Library</a>
    </div>

    <header class="mb-16 border-b border-cream-300 pb-10">
      <h1 class="text-4xl font-serif font-bold mb-4 text-charcoal-900">{branch.name}</h1>
      <p class="text-xl text-muted-foreground font-serif leading-relaxed">{branch.description}</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Main Content (Inbox & Library) -->
      <div class="md:col-span-2 space-y-16">
        
        <!-- Inbox -->
        <section>
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-lg font-semibold tracking-wide uppercase text-muted-foreground">Inbox</h2>
            <form method="POST" action={`/api/branches/${slug}/generate`}>
              <button type="submit" class="px-4 py-2 border border-cream-300 bg-transparent text-charcoal-900 rounded-md hover:bg-charcoal-900 hover:text-cream-50 focus:bg-charcoal-900 focus:text-cream-50 focus:border-charcoal-900 active:bg-charcoal-900 active:text-cream-50 active:border-charcoal-900 transition-colors font-medium text-sm">
                Find Recommendations
              </button>
            </form>
          </div>
          {state.inbox.length === 0 ? (
            <div class="p-12 border border-dashed border-cream-300 rounded-lg text-center">
              <p class="text-muted-foreground italic">No new recommendations.</p>
            </div>
          ) : (
             <ul class="space-y-6">
               {state.inbox.map(item => (
                 <li class="border border-cream-300 p-8 rounded-lg bg-paper-100 shadow-cozy hover:shadow-cozy-md transition-shadow">
                   <div class="flex gap-6">
                     {item.metadata?.coverImageUrl ? (
                       <img 
                         src={item.metadata.coverImageUrl} 
                         alt={`Cover for ${item.title}`}
                         class="w-24 h-36 object-cover rounded border border-cream-300 flex-shrink-0"
                         loading="lazy"
                       />
                     ) : (
                       <div class="w-24 h-36 bg-cream-200 rounded border border-cream-300 flex-shrink-0 flex items-center justify-center">
                         <svg class="w-12 h-12 text-cream-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
                         </svg>
                       </div>
                     )}
                     <div class="flex-1 min-w-0">
                       <h3 class="font-serif font-bold text-lg text-charcoal-900 mb-1">{item.title}</h3>
                       <p class="text-sm text-muted-foreground mb-3">by {item.author}</p>
                       {item.metadata?.firstPublishYear && (
                         <p class="text-xs text-muted-foreground mb-2">Published {item.metadata.firstPublishYear}</p>
                       )}
                       <p class="text-charcoal-800 mb-6 leading-relaxed">{item.reason}</p>
                       <div class="flex gap-2 flex-wrap">
                     <form method="POST" action={`/api/branches/${slug}/status`}>
                       <input type="hidden" name="itemTitle" value={item.title} />
                       <input type="hidden" name="status" value="ACCEPTED" />
                       <button type="submit" class="text-xs px-4 py-1.5 border border-cream-300 rounded-md bg-transparent hover:bg-sage-400 hover:text-cream-50 hover:border-sage-400 focus:bg-charcoal-900 focus:text-cream-50 focus:border-charcoal-900 active:bg-charcoal-900 active:text-cream-50 active:border-charcoal-900 transition-colors font-medium">Keep</button>
                     </form>
                     <form method="POST" action={`/api/branches/${slug}/status`}>
                       <input type="hidden" name="itemTitle" value={item.title} />
                       <input type="hidden" name="status" value="ALREADY_READ" />
                       <button type="submit" class="text-xs px-4 py-1.5 border border-cream-300 rounded-md bg-transparent hover:bg-sage-400 hover:text-cream-50 hover:border-sage-400 focus:bg-charcoal-900 focus:text-cream-50 focus:border-charcoal-900 active:bg-charcoal-900 active:text-cream-50 active:border-charcoal-900 transition-colors font-medium">Already Read</button>
                     </form>
                     <form method="POST" action={`/api/branches/${slug}/status`}>
                       <input type="hidden" name="itemTitle" value={item.title} />
                       <input type="hidden" name="status" value="DEFERRED" />
                       <button type="submit" class="text-xs px-4 py-1.5 border border-cream-300 rounded-md bg-transparent hover:bg-paper-200 focus:bg-charcoal-900 focus:text-cream-50 focus:border-charcoal-900 active:bg-charcoal-900 active:text-cream-50 active:border-charcoal-900 transition-colors font-medium">Maybe</button>
                     </form>
                     <form method="POST" action={`/api/branches/${slug}/status`}>
                       <input type="hidden" name="itemTitle" value={item.title} />
                       <input type="hidden" name="status" value="REJECTED" />
                       <button type="submit" class="text-xs px-4 py-1.5 border border-rose-300 text-rose-300 rounded-md bg-transparent hover:bg-rose-200 hover:text-charcoal-900 focus:bg-charcoal-900 focus:text-cream-50 focus:border-charcoal-900 active:bg-charcoal-900 active:text-cream-50 active:border-charcoal-900 transition-colors font-medium">Reject</button>
                     </form>
                       </div>
                     </div>
                   </div>
                 </li>
               ))}
             </ul>
          )}
        </section>

        <!-- Library (Shelf) -->
        <section>
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-lg font-semibold tracking-wide uppercase text-muted-foreground">Shelf</h2>
            <button class="px-4 py-2 border border-cream-300 rounded-md bg-transparent hover:bg-paper-200 focus:bg-charcoal-900 focus:text-cream-50 focus:border-charcoal-900 active:bg-charcoal-900 active:text-cream-50 active:border-charcoal-900 transition-colors font-medium text-sm">
              Write Reflection
            </button>
          </div>
          {state.library.length === 0 ? (
             <p class="text-muted-foreground italic">Your shelf is empty.</p>
          ) : (
            <ul class="space-y-4">
              {state.library.map(item => (
                <li class="flex items-start gap-4 border-b border-cream-300 pb-4">
                  {item.metadata?.coverImageUrl ? (
                    <img 
                      src={item.metadata.coverImageUrl} 
                      alt={`Cover for ${item.title}`}
                      class="w-16 h-24 object-cover rounded border border-cream-300 flex-shrink-0"
                      loading="lazy"
                    />
                  ) : (
                    <div class="w-16 h-24 bg-cream-200 rounded border border-cream-300 flex-shrink-0 flex items-center justify-center">
                      <svg class="w-8 h-8 text-cream-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
                      </svg>
                    </div>
                  )}
                  <div class="flex-1 min-w-0">
                    <div class="flex items-baseline justify-between gap-4">
                      <div class="min-w-0">
                        <span class="font-serif font-bold mr-2 text-charcoal-900">{item.title}</span>
                        <span class="text-sm text-muted-foreground">by {item.author}</span>
                        {item.metadata?.firstPublishYear && (
                          <span class="text-xs text-muted-foreground ml-2">({item.metadata.firstPublishYear})</span>
                        )}
                      </div>
                      <span class="text-xs uppercase tracking-wider text-soft-gray flex-shrink-0">{item.status}</span>
                    </div>
                  </div>
                </li>
              ))}
            </ul>
          )}
        </section>

      </div>

      <!-- Sidebar (History) -->
      <aside>
        <div>
           <h3 class="font-semibold mb-4 text-muted-foreground uppercase text-xs tracking-wider">History</h3>
           <ul class="space-y-4 text-sm border-l-2 border-cream-300 pl-5">
             {state.history.slice().reverse().map(event => (
               <li class="relative">
                 <div class="absolute -left-[26px] top-1.5 w-2.5 h-2.5 rounded-full bg-cream-300 border-2 border-paper-100"></div>
                 <p class="font-medium text-charcoal-800">{event.type.replace(/_/g, ' ')}</p>
                 <p class="text-xs text-muted-foreground mt-1">{new Date(event.timestamp).toLocaleDateString()}</p>
               </li>
             ))}
           </ul>
        </div>
      </aside>
    </div>
  </main>
</Layout>
