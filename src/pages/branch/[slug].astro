---
import { projectBranchState } from "../../domain/projection";
import Layout from "../../layouts/Layout.astro";
import { getBranch, getBranchEvents } from "../../lib/dal";

const { slug } = Astro.params;

if (!slug) {
	return Astro.redirect("/");
}

const branch = await getBranch(slug);
if (!branch) {
	return Astro.redirect("/404");
}

const events = await getBranchEvents(slug);
const state = projectBranchState(events);
const toRead = state.library.filter(
	(i) => i.status === "ACCEPTED" || i.status === "DEFERRED",
);
const read = state.library.filter((i) => i.status === "ALREADY_READ");
---

<Layout>
  <main class="container-wide py-8">
    <div class="mb-8">
      <a href="/" class="text-sm text-muted-foreground hover:text-charcoal-900 transition-colors inline-flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Library
      </a>
    </div>

    <header class="mb-12 border-b border-cream-300 pb-8">
      <div class="flex items-start justify-between gap-4 mb-4">
        <div class="flex-1">
          <h1 class="text-4xl font-serif font-bold mb-4 text-charcoal-900">{branch.name}</h1>
          <p class="text-xl text-muted-foreground font-serif leading-relaxed max-w-3xl">{branch.description}</p>
        </div>
        <!-- OPDS Feed Controls -->
        <div class="relative flex-shrink-0">
          <button
            id="opds-dropdown-btn"
            class="px-3 py-1.5 text-xs text-muted-foreground border border-cream-300 rounded-md bg-transparent hover:bg-paper-200 hover:text-charcoal-900 transition-colors inline-flex items-center gap-1"
            aria-label="OPDS Feed options"
          >
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
            </svg>
            OPDS Feed
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div
            id="opds-dropdown-menu"
            class="hidden absolute right-0 mt-1 w-48 bg-white border border-cream-300 rounded-md shadow-lg z-10"
          >
            <a
              href={`/api/branches/${slug}/opds`}
              target="_blank"
              rel="noopener noreferrer"
              class="block px-4 py-2 text-sm text-charcoal-900 hover:bg-paper-100 transition-colors first:rounded-t-md"
            >
              View Feed
            </a>
            <button
              id="copy-opds-btn"
              class="w-full text-left block px-4 py-2 text-sm text-charcoal-900 hover:bg-paper-100 transition-colors last:rounded-b-md"
            >
              <span id="copy-opds-text">Copy Feed URL</span>
            </button>
          </div>
        </div>
        </div>
      </div>
    </header>

    <!-- Book Covers Preview -->
    {(toRead.length > 0 || read.length > 0) && (
      <div class="mb-12">
        <div class="relative">
          <div class="book-covers-preview flex gap-4 overflow-x-auto pb-4">
            {[...toRead, ...read]
              .filter((item): item is typeof item & { metadata: { coverImageUrl: string } } =>
                !!item.metadata?.coverImageUrl
              )
              .slice(0, 8)
              .map((item, index) => (
                <div class="book-cover-item flex-shrink-0 relative group">
                  <img
                    src={item.metadata.coverImageUrl}
                    alt={`${item.title} cover`}
                    class="w-28 h-40 object-cover rounded shadow-cozy-md border-2 border-cream-300 hover:border-sage-400 transition-all cursor-pointer"
                    loading="lazy"
                    title={`${item.title} by ${item.author}`}
                  />
                </div>
              ))}
          </div>
          {/* Fade gradient overlay to indicate more books */}
          {([...toRead, ...read].filter(item => item.metadata?.coverImageUrl).length > 8) && (
            <div class="book-covers-fade absolute right-0 top-0 bottom-4 w-32 pointer-events-none"></div>
          )}
        </div>
        <p class="text-xs text-muted-foreground mt-3">
          {toRead.length > 0 && (
            <span>{toRead.length} {toRead.length === 1 ? 'book' : 'books'} to read</span>
          )}
          {toRead.length > 0 && read.length > 0 && <span> • </span>}
          {read.length > 0 && (
            <span>{read.length} {read.length === 1 ? 'book' : 'books'} read</span>
          )}
        </p>
      </div>
    )}

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">

      <!-- Main Content: Shelf (Left, Wider) -->
      <div class="lg:col-span-8 space-y-16">

        <!-- Shelf Section -->
        <section id="shelf-section">
          <div class="flex items-center justify-between mb-8">
            <div class="flex items-center gap-4">
              <h2 class="text-2xl font-serif font-semibold text-charcoal-900">Your Shelf</h2>
              <a href={`/branch/${slug}/import`} class="text-sm text-muted-foreground hover:text-charcoal-900 transition-colors underline">
                Import Books
              </a>
            </div>
            <a href={`/branch/${slug}/reflect`} class="px-4 py-2 border border-cream-300 rounded-md bg-transparent hover:bg-paper-200 focus:bg-charcoal-900 focus:text-cream-50 transition-colors font-medium text-sm">
              Write Reflection
            </a>
          </div>

          {state.library.length === 0 ? (
             <div class="p-12 border border-dashed border-cream-300 rounded-lg text-center bg-paper-50">
               <p class="text-muted-foreground italic mb-4">Your shelf is waiting for its first book.</p>
               <p class="text-sm text-muted-foreground mb-6">Get started by importing books from an OPDS catalog or generating recommendations.</p>
               <div class="flex gap-3 justify-center">
                 <a href={`/branch/${slug}/import`} class="px-6 py-2 bg-charcoal-900 text-white rounded-md hover:bg-charcoal-800 transition-colors font-medium text-sm">
                   Import from OPDS
                 </a>
                 <button onclick="document.getElementById('generate-btn')?.click()" class="px-6 py-2 border border-cream-300 rounded-md bg-transparent hover:bg-paper-200 transition-colors font-medium text-sm">
                   Generate Recommendations
                 </button>
               </div>
             </div>
          ) : (
            <div class="space-y-12">
              {/* To Read Group */}
              {toRead.length > 0 && (
                <div>
                  <h3 class="text-sm font-semibold tracking-wide uppercase text-muted-foreground mb-6 border-b border-cream-300 pb-2">To Read</h3>
                  <ul class="grid grid-cols-1 gap-6">
                    {toRead.map(item => (
                      <li class="flex items-start gap-6 p-4 rounded-lg hover:bg-paper-100 transition-colors group">
                        {item.metadata?.coverImageUrl ? (
                          <img
                            src={item.metadata.coverImageUrl}
                            alt={`Cover for ${item.title}`}
                            class="w-20 h-32 object-cover rounded shadow-sm flex-shrink-0"
                            loading="lazy"
                          />
                        ) : (
                          <div class="w-20 h-32 bg-cream-200 rounded shadow-sm flex-shrink-0 flex items-center justify-center">
                            <svg class="w-8 h-8 text-cream-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
                            </svg>
                          </div>
                        )}
                        <div class="flex-1 min-w-0 py-1">
                          <h4 class="font-serif font-bold text-xl text-charcoal-900 mb-1">{item.title}</h4>
                          <p class="text-muted-foreground mb-3">by {item.author} {item.metadata?.firstPublishYear && <span class="text-xs">({item.metadata.firstPublishYear})</span>}</p>
                          <p class="text-sm text-charcoal-700 leading-relaxed line-clamp-2 mb-4">{item.reason}</p>
                          <div class="flex gap-3 opacity-0 group-hover:opacity-100 transition-opacity">
                             <a href={`/branch/${slug}/reflect?itemTitle=${encodeURIComponent(item.title)}`} class="text-xs px-3 py-1.5 border border-cream-300 rounded bg-white hover:bg-sage-400 hover:text-white transition-colors">Mark as Read</a>
                          </div>
                        </div>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {/* Read Group */}
              {read.length > 0 && (
                <div>
                  <h3 class="text-sm font-semibold tracking-wide uppercase text-muted-foreground mb-6 border-b border-cream-300 pb-2">Read</h3>
                  <ul class="grid grid-cols-1 gap-4">
                    {read.map(item => (
                      <li class="flex items-center gap-4 p-3 rounded-lg hover:bg-paper-100 transition-colors opacity-75 hover:opacity-100">
                        <div class="w-12 h-16 bg-cream-200 rounded flex-shrink-0 overflow-hidden">
                           {item.metadata?.coverImageUrl && <img src={item.metadata.coverImageUrl} class="w-full h-full object-cover" />}
                        </div>
                        <div>
                          <h4 class="font-serif font-medium text-charcoal-900">{item.title}</h4>
                          <p class="text-xs text-muted-foreground">by {item.author}</p>
                        </div>
                        <div class="ml-auto">
                           <span class="text-xs px-2 py-1 bg-sage-400 text-white rounded-full">Read</span>
                        </div>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </div>
          )}
        </section>
      </div>

      <!-- Sidebar: Recommendations (Right, Narrower, Sticky) -->
      <aside class="lg:col-span-4 space-y-8 sticky top-8">
        <div class="bg-paper-50 border border-cream-300 rounded-xl p-6 shadow-sm">
          <div class="flex items-center justify-between mb-6">
            <h2 class="font-serif font-bold text-lg text-charcoal-900">Recommendations</h2>
            <form id="generate-form" method="POST" action={`/api/branches/${slug}/generate`}>
              <button id="generate-btn" type="submit" class="text-xs px-3 py-1.5 border border-charcoal-900 text-charcoal-900 rounded hover:bg-charcoal-900 hover:text-white transition-colors flex items-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed">
                <span>Refresh</span>
                <svg id="spinner" class="w-3 h-3 animate-spin hidden" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
              </button>
            </form>
          </div>

          <div id="inbox-container" class="space-y-4 min-h-[200px]">
            {state.inbox.length === 0 ? (
              <div class="text-center py-8 text-muted-foreground">
                <p class="text-sm italic mb-4">No recommendations yet.</p>
                <button onclick="document.getElementById('generate-btn').click()" class="text-sm underline hover:text-charcoal-900">Generate some?</button>
              </div>
            ) : (
              <ul class="space-y-4">
                {state.inbox.map(item => (
                  <li class="bg-white border border-cream-300 rounded-lg p-4 shadow-sm hover:shadow-md transition-all animate-fade-in">
                    <div class="flex gap-4 mb-3">
                      {item.metadata?.coverImageUrl ? (
                        <img src={item.metadata.coverImageUrl} class="w-16 h-24 object-cover rounded shadow-sm bg-cream-100" />
                      ) : (
                        <div class="w-16 h-24 bg-cream-200 rounded flex-shrink-0"></div>
                      )}
                      <div class="flex-1 min-w-0">
                        <h3 class="font-bold text-charcoal-900 leading-tight mb-1">{item.title}</h3>
                        <p class="text-xs text-muted-foreground mb-2">{item.author}</p>
                        <p class="text-xs text-charcoal-700 line-clamp-3">{item.reason}</p>
                      </div>
                    </div>
                    <div class="flex gap-2 mt-3">
                      <form class="flex-1" method="POST" action={`/api/branches/${slug}/status`}>
                        <input type="hidden" name="itemTitle" value={item.title} />
                        <input type="hidden" name="status" value="ACCEPTED" />
                        <button type="submit" class="w-full py-1.5 bg-charcoal-900 text-white text-xs rounded hover:bg-charcoal-800 transition-colors">Add to Shelf</button>
                      </form>
                      <form method="POST" action={`/api/branches/${slug}/status`}>
                        <input type="hidden" name="itemTitle" value={item.title} />
                        <input type="hidden" name="status" value="REJECTED" />
                        <button type="submit" class="px-3 py-1.5 border border-cream-300 text-muted-foreground text-xs rounded hover:bg-rose-50 hover:text-rose-600 hover:border-rose-200 transition-colors" title="Dismiss">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                        </button>
                      </form>
                    </div>
                  </li>
                ))}
              </ul>
            )}
          </div>
        </div>

        <!-- History (Compact) -->
        <div class="pl-4 border-l-2 border-cream-300">
           <h3 class="font-semibold mb-3 text-muted-foreground uppercase text-xs tracking-wider">Recent Activity</h3>
           <ul class="space-y-3 text-xs text-muted-foreground">
             {state.history.slice().reverse().slice(0, 5).map(event => (
               <li>
                 <span class="text-charcoal-800 font-medium">{event.type.replace(/_/g, ' ')}</span>
                 <span class="block text-[10px] opacity-75">{new Date(event.timestamp).toLocaleDateString()}</span>
               </li>
             ))}
           </ul>
        </div>
      </aside>
    </div>
  </main>
</Layout>

<script define:vars={{ slug }}>
  // Client-side logic for async recommendations
  const generateForm = document.getElementById('generate-form');
  const generateBtn = document.getElementById('generate-btn');
  const spinner = document.getElementById('spinner');
  const inboxContainer = document.getElementById('inbox-container');

  // OPDS feed dropdown functionality
  const opdsDropdownBtn = document.getElementById('opds-dropdown-btn');
  const opdsDropdownMenu = document.getElementById('opds-dropdown-menu');
  const copyOpdsBtn = document.getElementById('copy-opds-btn');
  const copyOpdsText = document.getElementById('copy-opds-text');

  // Toggle dropdown
  if (opdsDropdownBtn && opdsDropdownMenu) {
    opdsDropdownBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      opdsDropdownMenu.classList.toggle('hidden');
    });

    // Close dropdown when clicking outside
    document.addEventListener('click', (e) => {
      const target = e.target;
      if (target && !opdsDropdownBtn.contains(target) && !opdsDropdownMenu.contains(target)) {
        opdsDropdownMenu.classList.add('hidden');
      }
    });
  }

  // Copy URL functionality
  if (copyOpdsBtn && copyOpdsText) {
    copyOpdsBtn.addEventListener('click', async (e) => {
      e.preventDefault();
      e.stopPropagation();
      const opdsUrl = `${window.location.origin}/api/branches/${slug}/opds`;

      await navigator.clipboard.writeText(opdsUrl);
      const originalText = copyOpdsText.textContent;
      copyOpdsText.textContent = 'Copied!';

      setTimeout(() => {
        copyOpdsText.textContent = originalText;
        if (opdsDropdownMenu) {
          opdsDropdownMenu.classList.add('hidden');
        }
      }, 1500);
    });
  }

  // Check if inbox is empty on load, if so, trigger auto-generation
  // We can check the DOM content
  const isEmpty = inboxContainer && inboxContainer.innerText.includes('No recommendations yet');

  if (isEmpty) {
    // Trigger auto-generation silently if empty
    // We use a small delay to ensure hydration
    setTimeout(() => {
        if (generateForm) generateForm.dispatchEvent(new Event('submit'));
    }, 500);
  }

  if (generateForm) {
    generateForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      // UI Loading State
      if (generateBtn) {
        generateBtn.disabled = true;
        const span = generateBtn.querySelector('span');
        if (span) span.textContent = 'Generating...';
        if (spinner) spinner.classList.remove('hidden');
      }

      try {
        // Fire async request
        await fetch(generateForm.action, {
          method: 'POST',
          headers: {
            'Accept': 'application/json'
          }
        });

        // Start polling
        const pollInterval = setInterval(async () => {
          try {
            const res = await fetch(`/api/branches/${slug}/state`);
            const data = await res.json();

            // If we have items in inbox, reload the page to render them (simplest for Astro MPA)
            // Or we could client-side render, but that duplicates template logic.
            // For "smoothness", a page reload is okay if it's fast, OR we can partial reload.
            // Given this is Astro, a full reload is the standard way unless using View Transitions or islands.
            // We'll reload for now to ensure server-rendered templates are used.
            if (data.inbox && data.inbox.length > 0) {
              clearInterval(pollInterval);
              window.location.reload();
            }
          } catch (err) {
            console.error('Polling error', err);
          }
        }, 2000);

      } catch (error) {
        console.error('Generation request failed', error);
        // Reset UI
        if (generateBtn) {
          generateBtn.disabled = false;
          const span = generateBtn.querySelector('span');
          if (span) span.textContent = 'Refresh';
          if (spinner) spinner.classList.add('hidden');
        }
      }
    });
  }
</script>
