---
import Layout from '../../layouts/Layout.astro';
import { getBranch, getBranchEvents } from '../../lib/dal';
import { projectBranchState } from '../../domain/projection';

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/');
}

const branch = await getBranch(slug);
if (!branch) {
  return Astro.redirect('/404');
}

const events = await getBranchEvents(slug);
const state = projectBranchState(events);
---

<Layout>
  <main class="container mx-auto max-w-4xl py-12 px-4">
    <div class="mb-6">
      <a href="/" class="text-sm text-gray-500 hover:text-black">&larr; Library</a>
    </div>

    <header class="mb-12 border-b pb-8">
      <h1 class="text-4xl font-serif font-bold mb-4">{branch.name}</h1>
      <p class="text-xl text-gray-600 font-serif leading-relaxed">{branch.description}</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Main Content (Inbox & Library) -->
      <div class="md:col-span-2 space-y-12">
        
        <!-- Inbox -->
        <section>
          <h2 class="text-lg font-bold tracking-wide uppercase text-gray-400 mb-4">Inbox</h2>
          {state.inbox.length === 0 ? (
            <div class="p-8 border border-dashed rounded-lg text-center text-gray-400">
              <p>No new recommendations.</p>
            </div>
          ) : (
             <ul class="space-y-6">
               {state.inbox.map(item => (
                 <li class="border p-6 rounded-lg shadow-sm">
                   <h3 class="font-serif font-bold text-lg">{item.title}</h3>
                   <p class="text-sm text-gray-600 mb-2">by {item.author}</p>
                   <p class="text-gray-800 mb-4">{item.reason}</p>
                   <div class="flex gap-2">
                     <form method="POST" action={`/api/branches/${slug}/status`}>
                       <input type="hidden" name="itemTitle" value={item.title} />
                       <input type="hidden" name="status" value="ACCEPTED" />
                       <button type="submit" class="text-xs px-3 py-1 border rounded hover:bg-black hover:text-white transition-colors">Keep</button>
                     </form>
                     <form method="POST" action={`/api/branches/${slug}/status`}>
                       <input type="hidden" name="itemTitle" value={item.title} />
                       <input type="hidden" name="status" value="DEFERRED" />
                       <button type="submit" class="text-xs px-3 py-1 border rounded hover:bg-gray-100 transition-colors">Maybe</button>
                     </form>
                     <form method="POST" action={`/api/branches/${slug}/status`}>
                       <input type="hidden" name="itemTitle" value={item.title} />
                       <input type="hidden" name="status" value="REJECTED" />
                       <button type="submit" class="text-xs px-3 py-1 text-red-500 hover:bg-red-50 rounded transition-colors">Reject</button>
                     </form>
                   </div>
                 </li>
               ))}
             </ul>
          )}
        </section>

        <!-- Library (Shelf) -->
        <section>
          <h2 class="text-lg font-bold tracking-wide uppercase text-gray-400 mb-4">Shelf</h2>
          {state.library.length === 0 ? (
             <p class="text-gray-500 italic">Your shelf is empty.</p>
          ) : (
            <ul class="space-y-4">
              {state.library.map(item => (
                <li class="flex items-baseline justify-between border-b pb-2">
                  <div>
                    <span class="font-serif font-bold mr-2">{item.title}</span>
                    <span class="text-sm text-gray-600">by {item.author}</span>
                  </div>
                  <span class="text-xs uppercase tracking-wider text-gray-400">{item.status}</span>
                </li>
              ))}
            </ul>
          )}
        </section>

      </div>

      <!-- Sidebar (Controls & History) -->
      <aside class="space-y-8">
        <div class="bg-gray-50 p-6 rounded-lg">
          <h3 class="font-bold mb-4">Actions</h3>
          <form method="POST" action={`/api/branches/${slug}/generate`}>
             <button type="submit" class="w-full py-2 bg-black text-white rounded-md mb-2 hover:bg-gray-800">
               Generate Recommendations
             </button>
          </form>
          <button class="w-full py-2 border border-gray-300 rounded-md hover:bg-white">
            Write Reflection
          </button>
        </div>

        <div>
           <h3 class="font-bold mb-4 text-gray-400 uppercase text-xs tracking-wider">History</h3>
           <ul class="space-y-3 text-sm border-l-2 border-gray-100 pl-4">
             {state.history.slice().reverse().map(event => (
               <li class="relative">
                 <div class="absolute -left-[21px] top-1.5 w-2 h-2 rounded-full bg-gray-200"></div>
                 <p class="font-medium text-gray-700">{event.type.replace(/_/g, ' ')}</p>
                 <p class="text-xs text-gray-400">{new Date(event.timestamp).toLocaleDateString()}</p>
               </li>
             ))}
           </ul>
        </div>
      </aside>
    </div>
  </main>
</Layout>
