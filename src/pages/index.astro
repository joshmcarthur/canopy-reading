---
import Layout from '../layouts/Layout.astro';
import { getAllBranches, createBranch } from '../lib/dal';

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const name = data.get('name')?.toString();
    const description = data.get('description')?.toString();

    if (name && description) {
       const newBranch = await createBranch(name, description);
       return Astro.redirect(`/branch/${newBranch.slug}`);
    }
  } catch (error) {
    console.error(error);
  }
}

const branches = await getAllBranches();
// Sort by createdAt descending
branches.sort((a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime());
---

<Layout>
  <main class="container mx-auto max-w-2xl py-12 px-4">
    <header class="mb-12 text-center">
      <h1 class="text-3xl font-serif font-bold mb-4">Canopy</h1>
      <p class="text-gray-600 italic">Personal Reading System</p>
    </header>

    <section class="mb-12">
      <form method="POST" class="space-y-4 border p-6 rounded-lg bg-gray-50">
        <h2 class="text-lg font-medium">New Inquiry</h2>
        <div>
          <label for="name" class="block text-sm font-medium mb-1">Topic / Title</label>
          <input 
            type="text" 
            id="name" 
            name="name" 
            required 
            class="w-full px-3 py-2 border rounded-md"
            placeholder="e.g. History of Coffee"
          />
        </div>
        <div>
           <label for="description" class="block text-sm font-medium mb-1">Seed Prompt / Intent</label>
           <textarea 
             id="description" 
             name="description" 
             required 
             rows="3"
             class="w-full px-3 py-2 border rounded-md"
             placeholder="I want to understand the economic impact of coffee..."
           ></textarea>
        </div>
        <button type="submit" class="px-4 py-2 bg-black text-white rounded-md hover:bg-gray-800">
          Start Branch
        </button>
      </form>
    </section>

    <section>
      <h2 class="text-xl font-serif border-b pb-2 mb-6">Open Branches</h2>
      
      {branches.length === 0 ? (
        <p class="text-gray-500 text-center py-8">No branches yet.</p>
      ) : (
        <ul class="space-y-4">
          {branches.map(branch => (
            <li>
              <a href={`/branch/${branch.slug}`} class="block p-4 border rounded-md hover:bg-gray-50 transition-colors group">
                <h3 class="font-bold font-serif text-lg group-hover:underline">{branch.name}</h3>
                <p class="text-gray-600 text-sm mt-1 line-clamp-2">{branch.description}</p>
                <div class="mt-2 text-xs text-gray-400">
                  Started {new Date(branch.createdAt).toLocaleDateString()}
                </div>
              </a>
            </li>
          ))}
        </ul>
      )}
    </section>
  </main>
</Layout>
